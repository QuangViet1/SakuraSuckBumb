-- ฟังก์ชันบล็อกแบบที่ 1
local function holdBlockType1()
	local args = {
		"\016",
		"\254\002\000\006\001F\005\001"
	}
	while autoBlockEnabled do
		pcall(function()
			ReliableRemote:FireServer(unpack(args))
		end)
		task.wait(0.05)
	end
end

