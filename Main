-- ฟังก์ชันกด ProximityPrompt
local function interactPrompt(prompt)
	if fireproximityprompt then
		fireproximityprompt(prompt)
	else
		prompt.HoldDuration = 0
		prompt:InputHoldBegin()
		task.wait(0.1)
		prompt:InputHoldEnd()
	end
end

